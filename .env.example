# Required
GITHUB_TOKEN=ghp_your_token_here   # GitHub personal access token (read:user, public_repo scopes)

# Optional — server identity
# SERVER_NAME=screw-u-ats           # Displayed to MCP clients

# Optional — defaults shown
ALLOW_WRITES=false       # must be true to enable write tools
LOG_LEVEL=info           # debug | info | warn | error
# PORT=3000               # Set to enable HTTP+SSE transport in addition to stdio
# CHECK_PORT=4000         # Set to enable the public REST /check/:githubName endpoint (Hono, CORS-open)

# Optional — security (HTTP transport only)
# MCP_SECRET=your-secret-here    # If set, /mcp requires x-mcp-secret header to match
# MAX_BODY_BYTES=1048576          # Max request body size in bytes (default: 1 MB)
# MAX_SESSIONS=100                # Max concurrent HTTP sessions (default: 100)
# SESSION_TTL_MS=1800000          # Idle session eviction timeout in ms (default: 30 min)

# Optional — database (audit logging + knowledge search)
# DB_TYPE=postgres              # Storage adapter: "postgres" (default)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional — caching (omit to disable)
# REDIS_URL=redis://host:6379
# CACHE_TTL_DEFAULT=300           # Default cache TTL in seconds

# Optional — Lighthouse enrichment (include_lighthouse: true in score_candidate)
# PAGESPEED_API_KEY=              # Google PageSpeed Insights API key — free tier (25k req/day). Without a key,
#                                 # unauthenticated requests share a global quota that exhausts quickly.

# Optional — observability
# METRICS_INTERVAL=100            # Emit metrics summary every N tool calls
