# Port the screener-api HTTP server listens on.
# Server does not start if this is unset.
API_PORT=4001

# SQLite file path (libsql). Defaults to file:./screener.db
# DATABASE_URL=file:./screener.db

# JWT secret for Bearer token validation. Leave unset in local dev to skip auth.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JWT_SECRET=your-secret-here
