# Port the screener-api HTTP server listens on.
# Server does not start if this is unset.
API_PORT=4001

# SQLite file path (libsql). Defaults to file:./screener.db
# DATABASE_URL=file:./screener.db

# Allowed CORS origins. Comma-separated list, or * for open. Defaults to *.
# CORS_ORIGIN=https://myapp.com,https://admin.myapp.com

# Max request body size in bytes. Defaults to 65536 (64 KB).
# BODY_LIMIT_BYTES=65536

# Rate limiting. Defaults to 100 requests per IP per 60 seconds.
# RATE_LIMIT=100
# RATE_WINDOW_MS=60000

# JWT secret for Bearer token validation. Leave unset in local dev to skip auth.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JWT_SECRET=your-secret-here

# GitHub personal access token for the job runner. Required to call the GitHub API.
GITHUB_TOKEN=your_github_token_here

# Path to role definition .md files. Resolved relative to cwd (screener-api/).
# Defaults to ../knowledge/roles — correct when running from screener-api/.
# ROLES_DIR=../knowledge/roles
