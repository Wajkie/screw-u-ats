{
  "meta": {
    "title": "screener-api",
    "description": "REST API for the fullstack screener app — candidate management, async analysis jobs, and historical report snapshots.",
    "version": "0.1.0",
    "repo": "https://github.com/Wajkie/screw-u-ats"
  },
  "middleware": {
    "stack": ["secureHeaders", "cors", "bodyLimit", "rateLimit", "auth"],
    "description": "All middleware runs on every request in this order before routes are matched.",
    "layers": [
      {
        "id": "secureHeaders",
        "summary": "Sets security-related HTTP response headers",
        "headers": ["X-Content-Type-Options: nosniff", "X-Frame-Options: SAMEORIGIN", "Strict-Transport-Security", "Content-Security-Policy"],
        "config": "No env var — always on"
      },
      {
        "id": "cors",
        "summary": "Cross-origin resource sharing",
        "config": "CORS_ORIGIN — comma-separated allowed origins, or * for open. Defaults to *."
      },
      {
        "id": "bodyLimit",
        "summary": "Rejects requests whose Content-Length exceeds the configured limit",
        "responses": { "413": "Request body exceeds limit" },
        "config": "BODY_LIMIT_BYTES — default 65536 (64 KB)"
      },
      {
        "id": "rateLimit",
        "summary": "Sliding-window per-IP rate limiter",
        "headers": ["X-RateLimit-Limit", "X-RateLimit-Remaining", "X-RateLimit-Reset", "Retry-After (on 429)"],
        "responses": { "429": "Rate limit exceeded — try again later" },
        "config": "RATE_LIMIT (default 100), RATE_WINDOW_MS (default 60000)"
      },
      {
        "id": "auth",
        "summary": "JWT Bearer token validation via hono/jwt (HS256). No-op when JWT_SECRET is unset.",
        "responses": { "401": "Unauthorized — invalid or missing token (only when JWT_SECRET is set)" },
        "config": "JWT_SECRET — leave unset in local dev to skip auth"
      }
    ],
    "errorShape": { "error": "string" }
  },
  "endpoints": [
    {
      "id": "create-candidate",
      "method": "POST",
      "path": "/candidates",
      "summary": "Create a new candidate",
      "body": {
        "github_username": { "type": "string", "required": true, "description": "GitHub username — must be unique" },
        "display_name": { "type": "string", "required": false, "description": "Human-readable name shown in the UI" },
        "graduation_date": { "type": "string", "required": false, "description": "ISO date (YYYY-MM-DD). Pre-graduation repos are weighted lower in trajectory scoring." },
        "notes": { "type": "string", "required": false, "description": "Free-text recruiter notes" }
      },
      "responses": {
        "201": {
          "description": "Candidate created",
          "shape": {
            "id": "string",
            "github_username": "string",
            "display_name": "string | null",
            "graduation_date": "string | null",
            "notes": "string | null",
            "created_at": "string",
            "updated_at": "string"
          }
        },
        "400": { "description": "Missing or invalid fields" },
        "409": { "description": "github_username already exists" }
      },
      "example": {
        "request": {
          "github_username": "johndoe",
          "display_name": "John Doe",
          "graduation_date": "2024-06-01",
          "notes": "Strong trajectory, referred by Alice"
        },
        "response": {
          "id": "yEvCFU6MFw75wOfbzQFXP",
          "github_username": "johndoe",
          "display_name": "John Doe",
          "graduation_date": "2024-06-01",
          "notes": "Strong trajectory, referred by Alice",
          "created_at": "2026-05-30T10:00:00.000Z",
          "updated_at": "2026-05-30T10:00:00.000Z"
        }
      }
    },
    {
      "id": "list-candidates",
      "method": "GET",
      "path": "/candidates",
      "summary": "List all candidates with their latest report summary",
      "responses": {
        "200": {
          "description": "Array of candidates, newest first. latest_report is null if no analysis has run yet.",
          "shape": [
            {
              "id": "string",
              "github_username": "string",
              "display_name": "string | null",
              "graduation_date": "string | null",
              "notes": "string | null",
              "created_at": "string",
              "updated_at": "string",
              "latest_report": "{ id, best_fit, fit_score, created_at } | null"
            }
          ]
        }
      },
      "example": {
        "response": [
          {
            "id": "yEvCFU6MFw75wOfbzQFXP",
            "github_username": "johndoe",
            "display_name": "John Doe",
            "graduation_date": "2024-06-01",
            "notes": null,
            "created_at": "2026-05-30T10:00:00.000Z",
            "updated_at": "2026-05-30T10:00:00.000Z",
            "latest_report": {
              "id": "rpt_abc123",
              "best_fit": "junior-frontend",
              "fit_score": 72,
              "created_at": "2026-05-30T10:05:00.000Z"
            }
          }
        ]
      }
    },
    {
      "id": "get-candidate",
      "method": "GET",
      "path": "/candidates/:id",
      "summary": "Get a single candidate with their latest report summary",
      "params": {
        "id": { "type": "string", "description": "Candidate nanoid" }
      },
      "responses": {
        "200": {
          "description": "Candidate with latest_report summary (null if no analysis run yet)",
          "shape": {
            "id": "string",
            "github_username": "string",
            "display_name": "string | null",
            "graduation_date": "string | null",
            "notes": "string | null",
            "created_at": "string",
            "updated_at": "string",
            "latest_report": "{ id, best_fit, fit_score, created_at } | null"
          }
        },
        "404": { "description": "Candidate not found" }
      }
    },
    {
      "id": "update-candidate",
      "method": "PATCH",
      "path": "/candidates/:id",
      "summary": "Update display_name, graduation_date, or notes",
      "params": {
        "id": { "type": "string", "description": "Candidate nanoid" }
      },
      "body": {
        "display_name": { "type": "string | null", "required": false },
        "graduation_date": { "type": "string | null", "required": false, "description": "ISO date YYYY-MM-DD, or null to clear" },
        "notes": { "type": "string | null", "required": false }
      },
      "responses": {
        "200": { "description": "Updated candidate row" },
        "400": { "description": "Invalid graduation_date format" },
        "404": { "description": "Candidate not found" }
      },
      "example": {
        "request": { "notes": "Moved to top of shortlist after technical screen" },
        "response": {
          "id": "yEvCFU6MFw75wOfbzQFXP",
          "github_username": "johndoe",
          "display_name": "John Doe",
          "graduation_date": "2024-06-01",
          "notes": "Moved to top of shortlist after technical screen",
          "created_at": "2026-05-30T10:00:00.000Z",
          "updated_at": "2026-05-30T11:00:00.000Z"
        }
      }
    },
    {
      "id": "delete-candidate",
      "method": "DELETE",
      "path": "/candidates/:id",
      "summary": "Delete a candidate and cascade to their analysis jobs and reports",
      "params": {
        "id": { "type": "string", "description": "Candidate nanoid" }
      },
      "responses": {
        "204": { "description": "Deleted — no body" },
        "404": { "description": "Candidate not found" }
      }
    }
  ]
}
